generator client {
  provider = "prisma-client-js"
  previewFeatures = []
  engineType = "wasm"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id // e.g., 'superadmin', 'user'
  name        String    // e.g., 'Super Administrator', 'Member'
  description String?
  profiles    Profile[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id // e.g., 'settings:update'
  name        String
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")
  
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Profile {
  id            String         @id
  username      String         @unique
  displayName   String?        @map("display_name")
  avatarUrl     String?        @map("avatar_url")
  roleId        String         @default("user") @map("role_id")
  passwordHash  String?        @map("password_hash")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
  
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  watchHistory  WatchHistory[]
  bookmarks     Bookmark[]
  comments      Comment[]

  @@map("profiles")
}

model AnimeStatus {
  id     String  @id // 'ongoing', 'completed'
  name   String
  color  String? // 'primary', 'success', etc.
  animes Anime[]

  @@map("anime_statuses")
}

model AnimeType {
  id     String  @id // 'TV', 'Movie'
  name   String
  animes Anime[]

  @@map("anime_types")
}

model Season {
  id     String  @id // 'winter', 'spring'
  name   String
  animes Anime[]

  @@map("seasons")
}

model Anime {
  id            String         @id
  slug          String         @unique
  title         String
  synopsis      String?
  statusId      String         @map("status_id")
  typeId        String         @map("type_id")
  rating        String?
  score         Float?         @default(0)
  year          Int?
  seasonId      String?        @map("season_id")
  posterKey     String?        @map("poster_key")
  bannerKey     String?        @map("banner_key")
  totalEpisodes Int?           @map("total_episodes")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
  
  status        AnimeStatus    @relation(fields: [statusId], references: [id], onDelete: Restrict)
  type          AnimeType      @relation(fields: [typeId], references: [id], onDelete: Restrict)
  season        Season?        @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  
  genres        AnimeGenre[]
  episodes      Episode[]
  bookmarks     Bookmark[]

  @@map("anime")
}

model Genre {
  id      Int          @id @default(autoincrement())
  name    String       @unique
  slug    String       @unique
  animes  AnimeGenre[]

  @@map("genres")
}

model AnimeGenre {
  animeId String @map("anime_id")
  genreId Int    @map("genre_id")
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([animeId, genreId])
  @@map("anime_genres")
}

model Episode {
  id              String         @id
  animeId         String         @map("anime_id")
  episodeNumber   Float          @map("episode_number")
  title           String?
  synopsis        String?
  durationSeconds Int?           @map("duration_seconds")
  thumbnailKey    String?        @map("thumbnail_key")
  airedAt         DateTime?      @map("aired_at")
  viewCount       Int            @default(0) @map("view_count")
  createdAt       DateTime       @default(now()) @map("created_at")
  
  anime           Anime          @relation(fields: [animeId], references: [id], onDelete: Cascade)
  videoSources    VideoSource[]
  subtitles       Subtitle[]
  watchHistory    WatchHistory[]
  comments        Comment[]

  @@unique([animeId, episodeNumber])
  @@map("episodes")
}

model VideoQuality {
  id      String         @id // '360p', '1080p'
  name    String
  sources VideoSource[]

  @@map("video_qualities")
}

model VideoFormat {
  id      String         @id // 'hls', 'mp4'
  name    String
  sources VideoSource[]

  @@map("video_formats")
}

model VideoSource {
  id        String       @id
  episodeId String       @map("episode_id")
  qualityId String       @map("quality_id")
  formatId  String       @map("format_id")
  r2Key     String       @map("r2_key")
  url       String?
  fileSize  Int?         @map("file_size")
  isPrimary Boolean      @default(false) @map("is_primary")
  createdAt DateTime     @default(now()) @map("created_at")
  
  episode   Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  quality   VideoQuality @relation(fields: [qualityId], references: [id], onDelete: Restrict)
  format    VideoFormat  @relation(fields: [formatId], references: [id], onDelete: Restrict)

  @@map("video_sources")
}

model Subtitle {
  id        String   @id
  episodeId String   @map("episode_id")
  language  String
  label     String
  r2Key     String   @map("r2_key")
  createdAt DateTime @default(now()) @map("created_at")
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@map("subtitles")
}

model WatchHistory {
  userId    String   @map("user_id")
  episodeId String   @map("episode_id")
  progress  Int      @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@id([userId, episodeId])
  @@map("watch_history")
}

model BookmarkStatus {
  id        String     @id // 'watching', 'plan'
  name      String
  color     String?
  bookmarks Bookmark[]

  @@map("bookmark_statuses")
}

model Bookmark {
  userId   String         @map("user_id")
  animeId  String         @map("anime_id")
  statusId String         @default("plan") @map("status_id")
  addedAt  DateTime       @default(now()) @map("added_at")
  
  user     Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime    Anime          @relation(fields: [animeId], references: [id], onDelete: Cascade)
  status   BookmarkStatus @relation(fields: [statusId], references: [id], onDelete: Restrict)

  @@id([userId, animeId])
  @@map("bookmarks")
}

model Comment {
  id        String    @id
  episodeId String    @map("episode_id")
  userId    String    @map("user_id")
  parentId  String?   @map("parent_id")
  body      String
  isSpoiler Boolean   @default(false) @map("is_spoiler")
  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  episode   Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user      Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentToComment")

  @@map("comments")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("site_settings")
}
