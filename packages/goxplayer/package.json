{
  "name": "goxplayer",
  "version": "0.0.4",
  "description": "A modern, modular, and stateless Vue 3 video player with HLS support and premium UI.",
  "keywords": [
    "video",
    "player",
    "hls",
    "vue",
    "vue3",
    "streaming",
    "goxstream",
    "media"
  ],
  "author": "GoxStream Team",
  "license": "MIT",
  "homepage": "https://github.com/goxstream/goxplayer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goxstream/goxplayer.git"
  },
  "bugs": {
    "url": "https://github.com/goxstream/goxplayer/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/goxplayer.umd.js",
  "module": "./dist/goxplayer.es.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/goxplayer.es.js",
      "require": "./dist/goxplayer.umd.js"
    },
    "./style.css": "./dist/goxplayer.css"
  },
  "types": "./dist/types/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "lucide-vue-next": "^0.378.0",
    "hls.js": "^1.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "hls.js": "^1.6.16"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/language-core": "^3.2.8",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^5.0.0"
  }
}