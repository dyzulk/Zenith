{
  "name": "zenithstream",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "npx prisma generate && npx cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "npx prisma generate && nuxt prepare",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md,vue}\"",
    "deploy": "wrangler pages deploy dist",
    "build:vercel": "npx cross-env PAAS=vercel pnpm build",
    "build:netlify": "npx cross-env PAAS=netlify pnpm build",
    "build:pages": "npx cross-env PAAS=cloudflare-pages pnpm build",
    "build:render": "npx cross-env PAAS=render pnpm build"
  },
  "dependencies": {
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@iconify-json/lucide": "^1.2.104",
    "@iconify-json/simple-icons": "^1.2.80",
    "@internationalized/date": "^3.12.1",
    "@nuxt/ui": "^4.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/table-core": "^8.21.3",
    "@unovis/ts": "^1.6.5",
    "@unovis/vue": "^1.6.5",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "aws4fetch": "^1.0.19",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "lucide-vue-next": "^0.378.0",
    "nuxt": "^4.4.2",
    "pg": "^8.20.0",
    "pusher": "^5.3.3",
    "scule": "^1.3.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@cloudflare/workers-types": "^4.20240405.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "hls.js": "^1.5.8",
    "prettier": "latest",
    "prisma": "^7.8.0",
    "pusher-js": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^3.47.0"
  },
  "packageManager": "pnpm@9.0.0",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}