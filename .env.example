# DATABASE (Cloudflare D1)
# Local development uses SQLite via Wrangler/D1 integration.
# No DATABASE_URL required for local Drizzle D1.

# STORAGE (Universal S3)
# Supported DISK: auto (default), r2-binding, s3
FILESYSTEM_DISK=auto
S3_KEY=
S3_SECRET=
S3_BUCKET=
S3_REGION=auto
# Example Endpoints:
# R2: <account_id>.r2.cloudflarestorage.com
# AWS: s3.amazonaws.com
# DigitalOcean: sgp1.digitaloceanspaces.com
S3_ENDPOINT=
S3_PUBLIC_URL="https://cdn.yourdomain.com"

# AUTH (GOOGLE)
GOOGLE_CLIENT_ID=

# PUSHER REALTIME
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1
