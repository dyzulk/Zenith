# DATABASE (PostgreSQL)
# Use your connection string from Aiven, Supabase, Neon, or Self-hosted
DATABASE_URL="postgres://user:password@host:port/dbname?sslmode=require"

# SSL CONFIGURATION
# For local dev: provide path to CA cert file
DATABASE_SSL_CA_PATH="certs/aiven-ca.pem"
# For production: provide the raw CA certificate content
# DATABASE_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# CLOUDFLARE R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
R2_PUBLIC_DOMAIN="cdn.yourdomain.com"
R2_REGION="apac"

# AUTH (GOOGLE)
GOOGLE_CLIENT_ID=

# PUSHER REALTIME
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1
