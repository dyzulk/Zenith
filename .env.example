# =========================================================================
# ZENITH ENVIRONMENT VARIABLES SCENARIO
# =========================================================================
# Copy this file to .env and fill in the values.
# IMPORTANT: Never commit your actual .env file to version control.

# --- 1. SUPABASE (Frontend & Workers) ---
# Get these from your Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# --- 2. CLOUDFLARE R2 (Signer Worker) ---
# Get these from Cloudflare Dashboard -> R2 -> Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=anistream-media
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- 3. NATS (Real-time Messaging) ---
# If using a managed NATS provider or Cloudflare NATS connector
NATS_URL=nats://your-nats-server:4222
NATS_JWT=your-nats-user-jwt
NATS_SEED=your-nats-user-seed

# --- 4. DEVELOPMENT SETTINGS ---
NODE_ENV=development
PORT=3000

# =========================================================================
# CLOUDFLARE WORKERS SECRETS (Wrangler)
# =========================================================================
# For Workers, you must set secrets using the command line:
# wrangler secret put R2_SECRET_ACCESS_KEY
# wrangler secret put SUPABASE_ANON_KEY
